# ── EATIS Backend — Production Environment ─────────────────────────────────────
# Copy this file to .env and fill in real values before deploying

# Security — generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-32-char-secret-key

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Google Gemini AI (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Database — get from Supabase / Railway / Neon
DATABASE_URL=postgresql://user:password@host:5432/dbname

# CORS — set to your Vercel frontend URL
CORS_ORIGINS=https://your-app.vercel.app

# App settings
ENVIRONMENT=production
DEBUG=false
MODEL_DIR=/app/models
MODEL_RETRAIN_ON_STARTUP=false

# Admin account — created automatically on first startup
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChangeMe@123
ADMIN_NAME=System Administrator
